<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <title>Exercício 17</title>
    <style>
        #caixa {
            width: 150px;
            height: 150px;
            background-color: orange;
            margin-bottom: 10px;
        }
    </style>
</head>
<body>

    <div id="caixa"></div>

    <button onclick="limparCor()">Limpar Cor</button>

    <script>
        function limparCor() {
            const caixa = document.getElementById("caixa");
            caixa.style.backgroundColor = "white";
        }
    </script>

</body>
</html>
