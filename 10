<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <title>Exercício 10</title>
    <style>
        .caixa {
            width: 60px;
            height: 60px;
            background-color: gray;
            display: inline-block;
            margin: 5px;
        }
    </style>
</head>
<body>

    <div id="c1" class="caixa"></div>
    <div id="c2" class="caixa"></div>
    <div id="c3" class="caixa"></div>
    <div id="c4" class="caixa"></div>
    <div id="c5" class="caixa"></div>

    <script>
        document.getElementById("c1").style.backgroundColor = "red";
        document.getElementById("c2").style.backgroundColor = "orange";
        document.getElementById("c3").style.backgroundColor = "yellow";
        document.getElementById("c4").style.backgroundColor = "green";
        document.getElementById("c5").style.backgroundColor = "blue";
    </script>

</body>
</html>
