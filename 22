<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <title>Exercício 22</title>
    <style>
        .quadrado {
            width: 80px;
            height: 80px;
            background-color: gray;
            display: inline-block;
            margin: 5px;
        }
    </style>
</head>
<body>

    <div id="q1" class="quadrado"></div>
    <div id="q2" class="quadrado"></div>
    <div id="q3" class="quadrado"></div>
    <div id="q4" class="quadrado"></div>
    <div id="q5" class="quadrado"></div>

    <br><br>

    <button onclick="colorirTudo()">Colorir Tudo</button>

    <script>
        function colorirTudo() {
            document.getElementById("q1").style.backgroundColor = "red";
            document.getElementById("q2").style.backgroundColor = "orange";
            document.getElementById("q3").style.backgroundColor = "yellow";
            document.getElementById("q4").style.backgroundColor = "green";
            document.getElementById("q5").style.backgroundColor = "blue";
        }
    </script>

</body>
</html>
