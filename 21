<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <title>Exercício 21</title>
    <style>
        #caixa {
            width: 300px;
            height: 100px;
            background-color: green;
            color: white;
            padding: 10px;
            margin-bottom: 10px;
        }
    </style>
</head>
<body>

    <div id="caixa"></div>

    <button onclick="mostrarMensagem()">Mostrar Mensagem</button>

    <script>
        function mostrarMensagem() {
            document.getElementById("caixa").innerHTML = "Cor alterada com sucesso!";
        }
    </script>

</body>
</html>
